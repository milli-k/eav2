# ---- Omni REST API (server-side only) ----
# API host (the .omniapp.co / playground domain, NOT the embed domain). Trailing slash OK.
OMNI_API_BASE=https://milli-test.playground.exploreomni.dev
# API key from Settings > API Keys (or a Personal Access Token).
OMNI_API_KEY=omni_osk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Hub (base) shared model id that the per-tenant extensions extend.
OMNI_HUB_MODEL_ID=73a858a3-6778-47b7-8fee-9facd105d30e

# ---- Omni Embed (server-side only) ----
# Embed hostname ONLY — no https://, no port. For prod orgs this is <org>.embed-omniapp.co.
# For this playground instance, set to the embed domain shown in Admin > Embed.
OMNI_EMBED_HOST=milli-test.playground.exploreomni.dev
# Embed secret from Admin > Embed. REQUIRED for the iframe to load.
OMNI_EMBED_SECRET=replace-with-embed-secret

# ---- Demo embed user (identifies the viewer to Omni) ----
OMNI_EMBED_USER_EMAIL=embed-demo@example.com
OMNI_EMBED_USER_NAME=Embed Demo User
